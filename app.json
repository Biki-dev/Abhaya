{
  "expo": {
    "name": "Abhaya",
    "slug": "saathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "locationAlwaysAndWhenInUsePermissionAlert": "Abhaya needs access to your location for safety features.",
        "locationWhenInUsePermissionAlert": "Abhaya needs access to your location while using the app.",
        "microphone": {
          "microphonePermissionAlert": "Abhaya needs microphone access to record emergency audio."
        }
      },
      "bundleIdentifier": "com.trialssd.Abhaya"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.trialssd.Abhaya",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissionAlert": "Abhaya needs access to your location for safety features.",
          "locationWhenInUsePermissionAlert": "Abhaya needs access to your location while using the app."
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": []
          }
        }
      ]
    ],
    "assets": [
      "./assets/ei"
    ],
    "extra": {
      "eas": {
        "projectId": "49b6337a-8640-4bff-bf92-72540df80bdf"
      },
      "apiBaseUrl": "https://abhaya-backend.onrender.com"
    },
    "owner": "bikide"
  }
}
